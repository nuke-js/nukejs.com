{
  "compilerOptions": {
    "target": "es2022",
    "jsx": "react-jsx",
    "module": "es2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false,
    "noEmit": false,
    "resolveJsonModule": true,
    "outDir": "./dist"
  }
}